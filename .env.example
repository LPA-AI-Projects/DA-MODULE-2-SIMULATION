# Server port (Railway sets PORT automatically)
PORT=3001

# Redis connection URL — use the FULL value from Railway Redis → Variables → REDIS_URL
# Do NOT build it yourself (that causes redis://:undefined@... crashes).
# In Railway app service, set: REDIS_URL = ${{Redis.REDIS_URL}}
# (replace "Redis" with your Redis service name if different)
REDIS_URL=redis://default:password@hostname:6379

# Trainer login access code
TRAINER_CODE=2468

# Optional: restrict Socket.io CORS to your Railway domain
# CORS_ORIGIN=https://your-app.up.railway.app
